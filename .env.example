# Provision a Postgres database in Vercel: Storage tab -> Create Database ->
# Postgres, then Connect it to this project. That auto-injects
# DATABASE_URL / POSTGRES_URL as environment variables on the Vercel project.
#
# For local `npm run seed` or `vercel dev`, copy this file to .env.local and
# fill in the same connection string (Storage -> your database -> .env.local tab).
DATABASE_URL=

# Any long random string, used to sign session cookies. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
